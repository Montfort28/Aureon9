generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum UserRole {
  SUPER_ADMIN
  EXECUTIVE
  LEGAL_COMPLIANCE
  QUALIFICATIONS
  CUSTOMER_SUCCESS
  FINANCE_TREASURY
  MEMBER
  PARTNER
  OPERATOR
}

enum ParticipantClassCode {
  GENERAL_MEMBER
  CUSTOMER
  CHANNEL_PARTNER
  DEVELOPER
  STRATEGIC_PARTNER
  OEM_PARTNER
  TRADE_OPERATOR
  CAPITAL_PARTICIPANT
  SETTLEMENT_PARTICIPANT
  INSTITUTIONAL_PARTICIPANT
}

enum MembershipTierCode {
  MEMBER
  ASSOCIATE
  CERTIFIED
  EXECUTIVE
  STRATEGIC
  FOUNDING
  SOVEREIGN
}

enum VerificationLevel {
  UNVERIFIED
  BASIC_VERIFIED
  IDENTITY_VERIFIED
  COMMERCIAL_VERIFIED
  INSTITUTIONAL_VERIFIED
  CAPITAL_VERIFIED
  GOVERNANCE_APPROVED
}

enum VerificationStatus {
  PENDING
  UNDER_REVIEW
  APPROVED
  REJECTED
  SUSPENDED
}

enum ReviewQueueStatus {
  PENDING
  UNDER_REVIEW
  REQUESTED_MORE_DOCUMENTS
  ESCALATED
  APPROVED
  REJECTED
  SUSPENDED
}

enum ReviewActionType {
  CREATE_CASE
  ASSIGN_REVIEWER
  MOVE_TO_UNDER_REVIEW
  REQUEST_MORE_DOCUMENTS
  ESCALATE
  APPROVE
  REJECT
  SUSPEND
  ADD_NOTE
}

enum DocumentReviewStatus {
  RECEIVED
  UNDER_REVIEW
  ACCEPTED
  REJECTED
  REPLACEMENT_REQUIRED
}

enum WalletTransactionType {
  REWARD_CREDIT
  COMMISSION_CREDIT
  REFERRAL_BONUS
  REDEMPTION
  WITHDRAWAL
  SETTLEMENT
  ADJUSTMENT
}

enum OpportunityType {
  INVESTMENT
  TRADE
  TOURISM
  PARTNERSHIP
  CAREER
  MARKETPLACE
}

enum OpportunityAccessRule {
  PUBLIC
  VERIFIED_ONLY
  CERTIFIED_PLUS
  EXECUTIVE_PLUS
  STRATEGIC_PLUS
  INVITE_ONLY
}

model User {
  id                String               @id @default(cuid())
  email             String               @unique
  name              String?
  passwordHash      String?
  role              UserRole             @default(MEMBER)
  isActive          Boolean              @default(true)
  isEmailVerified   Boolean              @default(false)
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt
  memberProfile     MemberProfile?
  createdAuditLogs  AuditLog[]           @relation("AuditActor")

  @@map("users")
}

model ParticipantClass {
  id                String               @id @default(cuid())
  code              ParticipantClassCode @unique
  name              String
  description       String?
  isActive          Boolean              @default(true)
  profiles          MemberProfile[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@map("participant_classes")
}

model MembershipTier {
  id                String               @id @default(cuid())
  code              MembershipTierCode   @unique
  name              String
  rank              Int
  description       String?
  isActive          Boolean              @default(true)
  profiles          MemberProfile[]
  createdAt         DateTime             @default(now())
  updatedAt         DateTime             @updatedAt

  @@map("membership_tiers")
}

model MemberProfile {
  id                   String               @id @default(cuid())
  userId               String               @unique
  participantClassId   String
  tierId               String
  verificationLevel    VerificationLevel    @default(UNVERIFIED)
  displayName          String?
  country              String?
  phone                String?
  businessName         String?
  referralCode         String               @unique
  referredByProfileId  String?
  aurexWalletId        String?
  status               String               @default("ACTIVE")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt

  user                 User                 @relation(fields: [userId], references: [id])
  participantClass     ParticipantClass     @relation(fields: [participantClassId], references: [id])
  tier                 MembershipTier       @relation(fields: [tierId], references: [id])
  wallet               AurexWallet?
  verificationRecords  VerificationRecord[]
  documents            MemberDocument[]
  referralsSent        Referral[]           @relation("ReferralSender")
  referralsReceived    Referral[]           @relation("ReferralReceiver")
  opportunityApplications OpportunityApplication[]

  @@map("member_profiles")
}

model VerificationRecord {
  id                   String               @id @default(cuid())
  memberProfileId      String
  requestedLevel       VerificationLevel
  status               VerificationStatus   @default(PENDING)
  queueStatus          ReviewQueueStatus    @default(PENDING)
  notes                String?
  reviewedByUserId     String?
  assignedReviewerId   String?
  submittedAt          DateTime             @default(now())
  reviewedAt           DateTime?
  memberProfile        MemberProfile        @relation(fields: [memberProfileId], references: [id])
  actions              ReviewAction[]

  @@map("verification_records")
}

model MemberDocument {
  id                   String               @id @default(cuid())
  memberProfileId      String
  documentType         String
  verificationPurpose  String?
  fileUrl              String
  storageKey           String?
  fileName             String
  mimeType             String?
  sizeBytes            Int?
  reviewStatus         DocumentReviewStatus @default(RECEIVED)
  uploadedAt           DateTime             @default(now())
  memberProfile        MemberProfile        @relation(fields: [memberProfileId], references: [id])

  @@map("member_documents")
}

model ReviewAction {
  id                   String            @id @default(cuid())
  verificationRecordId String
  actionType           ReviewActionType
  actorUserId          String?
  notes                String?
  payloadJson          Json?
  createdAt            DateTime          @default(now())
  verificationRecord   VerificationRecord @relation(fields: [verificationRecordId], references: [id])

  @@map("review_actions")
}

model AurexWallet {
  id                   String               @id @default(cuid())
  memberProfileId      String               @unique
  balance              Decimal              @default(0) @db.Decimal(18, 4)
  currencyCode         String               @default("ARX")
  createdAt            DateTime             @default(now())
  updatedAt            DateTime             @updatedAt
  memberProfile        MemberProfile        @relation(fields: [memberProfileId], references: [id])
  transactions         WalletTransaction[]

  @@map("aurex_wallets")
}

model WalletTransaction {
  id                   String               @id @default(cuid())
  walletId             String
  type                 WalletTransactionType
  amount               Decimal              @db.Decimal(18, 4)
  reference            String?
  notes                String?
  createdAt            DateTime             @default(now())
  wallet               AurexWallet          @relation(fields: [walletId], references: [id])

  @@map("wallet_transactions")
}

model Referral {
  id                    String              @id @default(cuid())
  senderProfileId       String
  receiverProfileId     String?
  receiverEmail         String?
  campaignCode          String?
  status                String              @default("PENDING")
  createdAt             DateTime            @default(now())
  sender                MemberProfile       @relation("ReferralSender", fields: [senderProfileId], references: [id])
  receiver              MemberProfile?      @relation("ReferralReceiver", fields: [receiverProfileId], references: [id])

  @@map("referrals")
}

model Organization {
  id                    String               @id @default(cuid())
  name                  String
  description           String?
  country               String?
  businessType          String?
  website               String?
  contactEmail          String?
  contactPhone          String?
  isActive              Boolean              @default(true)
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  opportunities         Opportunity[]

  @@map("organizations")
}

model Opportunity {
  id                    String               @id @default(cuid())
  title                 String
  description           String?
  type                  OpportunityType
  accessRule            OpportunityAccessRule
  organizationId        String?
  isPublished           Boolean              @default(false)
  country               String?
  createdAt             DateTime             @default(now())
  updatedAt             DateTime             @updatedAt
  organization          Organization?        @relation(fields: [organizationId], references: [id])
  applications          OpportunityApplication[]

  @@map("opportunities")
}

model OpportunityApplication {
  id                    String               @id @default(cuid())
  memberProfileId       String
  opportunityId         String
  status                String               @default("SUBMITTED")
  notes                 String?
  submittedAt           DateTime             @default(now())
  reviewedAt            DateTime?
  reviewedByUserId      String?
  memberProfile         MemberProfile        @relation(fields: [memberProfileId], references: [id])
  opportunity           Opportunity          @relation(fields: [opportunityId], references: [id])

  @@map("opportunity_applications")
}

model AuditLog {
  id                    String               @id @default(cuid())
  actorUserId           String?
  entityType            String
  entityId              String
  action                String
  payloadJson           Json?
  createdAt             DateTime             @default(now())
  actor                 User?                @relation("AuditActor", fields: [actorUserId], references: [id])

  @@map("audit_logs")
}

// ==================== AUREON9 GOVERNANCE SYSTEM ====================

enum MemberStatus {
  ACTIVE
  INACTIVE
  SUSPENDED
  PENDING
}

enum SourceSystem {
  AAL
  ODIEXA
  ODIEBOARD
  OPI_INTELLIGENCE
  SUBSCRIPTION
}

enum PoolType {
  FOUNDERS
  PERFORMANCE
  OPERATIONS_RESERVE
  TREASURY_GROWTH
  STRATEGIC
}

enum ReviewStatus {
  PENDING
  APPROVED
  REJECTED
  BLOCKED
}

enum CreditType {
  EARNED_ARX
  FOUNDING_CREDIT
  BONUS
  LOCKED
}

enum VestingStatus {
  IMMEDIATE
  LOCKED
  RELEASED
}

model AureonTier {
  id                Int      @id
  name              String   @unique
  arc               String
  multiplier        Decimal  @db.Decimal(10, 4)
  upgradeType       String
  marketplaceAccess String?
  governanceAccess  String?
  capitalAccess     String?
  publicRecognition Boolean  @default(false)
  members           AureonMember[]
  roles             AureonRole[]
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt
}

model AureonRole {
  id                    String   @id @default(cuid())
  name                  String   @unique
  function              String
  authority             String?
  compensationRights    String?
  certificationRequired Int
  activeRole            Boolean  @default(true)
  minimumTierId         Int?
  minimumTier           AureonTier? @relation(fields: [minimumTierId], references: [id])
  members               AureonMember[]
  createdAt             DateTime @default(now())
  updatedAt             DateTime @updatedAt
}

model AureonMember {
  id                 String              @id @default(cuid())
  fullName           String
  email              String              @unique
  phone              String?
  country            String?
  tierId             Int
  tier               AureonTier          @relation(fields: [tierId], references: [id])
  assignedRoleId     String?
  assignedRole       AureonRole?         @relation(fields: [assignedRoleId], references: [id])
  certificationLevel Int                 @default(1)
  status             MemberStatus        @default(PENDING)
  verificationLevel  VerificationLevel   @default(BASIC_VERIFIED)
  baseUnits          Decimal             @default(0) @db.Decimal(18, 4)
  sponsorId          String?
  sponsor            AureonMember?       @relation("SponsorTree", fields: [sponsorId], references: [id])
  referrals          AureonMember[]      @relation("SponsorTree")
  joinDate           DateTime            @default(now())
  lastActivityDate   DateTime?
  complianceStatus   ReviewStatus        @default(PENDING)
  activityLedger     ActivityLedger[]
  revenueEvents      RevenueEvent[]
  certifications     CertificationRecord[]
  walletEntries      AurexWalletLedger[]
  distributions      Distribution[]
  upgradeRequests    UpgradeRequest[]
  createdAt          DateTime            @default(now())
  updatedAt          DateTime            @updatedAt

  @@map("aureon_members")
}

model CertificationRecord {
  id                  String       @id @default(cuid())
  memberId            String
  member              AureonMember @relation(fields: [memberId], references: [id])
  certificationLevel  Int
  courseCompleted     Boolean      @default(false)
  quizScore           Decimal?     @db.Decimal(5, 2)
  practicalTestPassed Boolean      @default(false)
  division4Review     ReviewStatus @default(PENDING)
  approvedBy          String?
  issueDate           DateTime?
  reviewDate          DateTime?
  createdAt           DateTime     @default(now())

  @@map("certification_records")
}

model ActivityLedger {
  id             String       @id @default(cuid())
  memberId       String
  member         AureonMember @relation(fields: [memberId], references: [id])
  activityType   String
  sourceSystem   SourceSystem
  valueScore     Decimal      @default(0) @db.Decimal(18, 4)
  revenueValue   Decimal      @default(0) @db.Decimal(18, 2)
  evidenceLink   String?
  verified       Boolean      @default(false)
  activityDate   DateTime     @default(now())
  createdAt      DateTime     @default(now())

  @@map("activity_ledgers")
}

model RevenueEvent {
  id                  String       @id @default(cuid())
  source              SourceSystem
  grossValue          Decimal      @db.Decimal(18, 2)
  costs               Decimal      @default(0) @db.Decimal(18, 2)
  ndv                 Decimal      @db.Decimal(18, 2)
  currency            String       @default("USD")
  responsibleMemberId String?
  responsibleMember   AureonMember? @relation(fields: [responsibleMemberId], references: [id])
  verifiedByTreasury  Boolean      @default(false)
  eventDate           DateTime     @default(now())
  poolAllocation      PoolAllocation?
  createdAt           DateTime     @default(now())

  @@map("revenue_events")
}

model PoolAllocation {
  id                 String       @id @default(cuid())
  revenueEventId     String       @unique
  revenueEvent       RevenueEvent @relation(fields: [revenueEventId], references: [id])
  foundersPool       Decimal      @default(0) @db.Decimal(18, 2)
  performancePool    Decimal      @default(0) @db.Decimal(18, 2)
  operationsReserve  Decimal      @default(0) @db.Decimal(18, 2)
  treasuryGrowth     Decimal      @default(0) @db.Decimal(18, 2)
  strategicPool      Decimal      @default(0) @db.Decimal(18, 2)
  policyVersion      String
  approvedByDivision2 Boolean     @default(false)
  createdAt          DateTime     @default(now())
  distributions      Distribution[]

  @@map("pool_allocations")
}

model Distribution {
  id               String           @id @default(cuid())
  poolAllocationId String
  poolAllocation   PoolAllocation   @relation(fields: [poolAllocationId], references: [id])
  memberId         String
  member           AureonMember     @relation(fields: [memberId], references: [id])
  poolType         PoolType
  effectiveUnits   Decimal          @db.Decimal(18, 4)
  amount           Decimal          @db.Decimal(18, 2)
  arxAmount        Decimal?         @db.Decimal(18, 4)
  status           ReviewStatus     @default(PENDING)
  period           String
  createdAt        DateTime         @default(now())

  @@map("distributions")
}

model AurexWalletLedger {
  id               String         @id @default(cuid())
  memberId         String
  member           AureonMember   @relation(fields: [memberId], references: [id])
  creditType       CreditType
  amount           Decimal        @db.Decimal(18, 4)
  sourcePool       PoolType?
  vestingStatus    VestingStatus  @default(IMMEDIATE)
  complianceStatus ReviewStatus   @default(PENDING)
  releaseDate      DateTime?
  createdAt        DateTime       @default(now())

  @@map("aurex_wallet_ledgers")
}

model UpgradeRequest {
  id               String       @id @default(cuid())
  memberId         String
  member           AureonMember @relation(fields: [memberId], references: [id])
  currentTierId    Int
  requestedTierId  Int
  upgradeVector    String
  evidence         String?
  division4Review  ReviewStatus @default(PENDING)
  division1Review  ReviewStatus @default(PENDING)
  division7Review  ReviewStatus @default(PENDING)
  finalStatus      ReviewStatus @default(PENDING)
  createdAt        DateTime     @default(now())
  updatedAt        DateTime     @updatedAt

  @@map("upgrade_requests")
}
